<?xml version="1.0" encoding="UTF-8"?>
<?mso-application progid="Excel.Sheet"?>
<Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet"
 xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet">
<Styles>
<Style ss:ID="title">
  <Font ss:Bold="1" ss:Size="15" ss:Color="#1F3864"/>
  <Alignment ss:Vertical="Center"/>
</Style>
<Style ss:ID="meta">
  <Font ss:Italic="1" ss:Size="10" ss:Color="#595959"/>
  <Alignment ss:Vertical="Center"/>
</Style>
<Style ss:ID="header">
  <Font ss:Bold="1" ss:Size="11" ss:Color="#FFFFFF"/>
  <Interior ss:Color="#1F3864" ss:Pattern="Solid"/>
  <Alignment ss:Horizontal="Center" ss:Vertical="Center"/>
  <Borders>
    <Border ss:Position="Bottom" ss:LineStyle="Continuous" ss:Weight="2" ss:Color="#C9A227"/>
  </Borders>
</Style>
<Style ss:ID="rowEven">
  <Font ss:Size="10" ss:Color="#1F3864"/>
  <Interior ss:Color="#DCE6F1" ss:Pattern="Solid"/>
  <Alignment ss:Vertical="Center"/>
  <Borders>
    <Border ss:Position="Bottom" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#BDD7EE"/>
  </Borders>
</Style>
<Style ss:ID="rowOdd">
  <Font ss:Size="10" ss:Color="#1F3864"/>
  <Interior ss:Color="#FFFFFF" ss:Pattern="Solid"/>
  <Alignment ss:Vertical="Center"/>
  <Borders>
    <Border ss:Position="Bottom" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#BDD7EE"/>
  </Borders>
</Style>
<Style ss:ID="progressEven">
  <Font ss:Bold="1" ss:Size="10" ss:Color="#375623"/>
  <Interior ss:Color="#DCE6F1" ss:Pattern="Solid"/>
  <Alignment ss:Vertical="Center"/>
  <Borders>
    <Border ss:Position="Bottom" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#BDD7EE"/>
  </Borders>
</Style>
<Style ss:ID="progressOdd">
  <Font ss:Bold="1" ss:Size="10" ss:Color="#375623"/>
  <Interior ss:Color="#FFFFFF" ss:Pattern="Solid"/>
  <Alignment ss:Vertical="Center"/>
  <Borders>
    <Border ss:Position="Bottom" ss:LineStyle="Continuous" ss:Weight="1" ss:Color="#BDD7EE"/>
  </Borders>
</Style>
</Styles>
